<section class="py-5 bg-primary bg-opacity-75">
    <div class="container">
        
        <form id="movieSearchForm" class="search-form mx-auto">
            <div class="input-group rounded-pill overflow-hidden shadow-sm">
                <input
                    class="form-control"
                    type="text"
                    id="searchInput"
                    placeholder="Search by entering a movie or series title..."
                    required
                >
                <button class="btn btn-light" type="submit">
                    <i class="fas fa-search"></i>
                </button>
            </div>
        </form>

        <p class="text-center text-light fw-bold fs-4 mt-4" id="userFeedback"> Enter a movie to get started </p>

    </div>
</section>

<section class="py-4">
    <div class="container">
        <div class="row row-cols-2 row-cols-md-4 row-cols-lg-5 g-4" id="cardContainer">
            <!-- Movie cards will be dynamically inserted here -->
            <!-- test card -->
            <!-- <div class="col mb-5">
                <div class="movie-card card h-100 border-0 shadow-lg">
                    <img
