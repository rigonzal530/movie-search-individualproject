        </div>
    </div>
    
    <div class="text-center mt-4">
        <button id="loadMore" type="button" class="btn btn-primary d-none">Load More</button>
    </div>
</section>

<div class="modal fade" id="movieDetailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title fw-bold" id="movieTitle"></h5>
                <button
                    type="button"
                    class="btn-close"
                    data-bs-dismiss="modal"
                    aria-label="Close">
                </button>
            </div>

            <div class="modal-body">
                <img id="moviePoster">
                <p id="movieId"></p>
                <p id="moviePlot"></p>
                <p id="movieRating"></p>
                <p id="movieRelease"></p>
                <p class="text-center fw-bold mb-0"> Would you like to save this result? </p>
            </div>
            
            <div class="modal-footer mx-auto">
                <button id="confirmSave" type="button" class="btn btn-success me-2"> Yes </button>
                <button type="button" class="btn btn-outline-danger" data-bs-dismiss="modal"> No </button>
            </div>
            
        </div>
    </div>
</div>